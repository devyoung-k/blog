---
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import Layout from '../layouts/Layout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section class="mx-auto max-w-2xl px-6 pt-20 pb-16 sm:pt-28">
    <p class="meta mb-6">since 2026</p>
    <h1
      class="font-serif text-3xl leading-[1.2] tracking-tight text-(--fg) sm:text-[2.5rem]"
    >
      읽고, 쓰고, <span class="italic text-(--accent)">짓는</span> 기록.
    </h1>
    <p
      class="mt-6 max-w-xl text-[15px] leading-relaxed text-(--fg-muted)"
    >
      개발자 devyoung의 노트. 코드를 짓는 과정에서 배운 것, 흘려보내기
      아까운 생각, 그리고 그 사이의 잔상들을 모아둡니다.
    </p>
  </section>

  <section
    class="mx-auto max-w-2xl border-t border-(--rule) px-6 py-12"
  >
    <div class="mb-8 flex items-baseline justify-between">
      <h2 class="text-base font-semibold tracking-tight">최근 글</h2>
      <a
        href="/blog"
        class="meta no-underline hover:text-(--fg)"
      >
        전체 보기 →
      </a>
    </div>

    {
      posts.length === 0 ? (
        <p class="text-sm text-(--fg-muted)">
          아직 발행한 글이 없습니다.
        </p>
      ) : (
        <ul class="flex flex-col">
          {posts.map((post) => (
            <li class="border-b border-(--rule) last:border-b-0">
              <a
                href={`/blog/${post.id}/`}
                class="group flex flex-col gap-1 py-5 no-underline sm:flex-row sm:items-baseline sm:gap-6"
              >
                <span class="meta sm:w-28 sm:shrink-0">
                  <FormattedDate date={post.data.pubDate} />
                </span>
                <div class="flex-1">
                  <h3
                    class="text-[17px] font-medium tracking-tight transition-colors group-hover:text-(--accent)"
                  >
                    {post.data.title}
                  </h3>
                  {post.data.description && (
                    <p class="mt-1 text-sm text-(--fg-muted)">
                      {post.data.description}
                    </p>
                  )}
                </div>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</Layout>
